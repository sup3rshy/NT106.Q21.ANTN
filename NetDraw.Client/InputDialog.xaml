<Window x:Class="NetDraw.Client.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập Text" Height="160" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <StackPanel Margin="15">
        <TextBlock x:Name="TxtPrompt" Text="Nhập nội dung:" Foreground="#CDD6F4" FontSize="13" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtInput" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                 FontSize="14" Padding="8,5" Text="Hello!" KeyDown="TxtInput_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="70" Margin="0,0,8,0" Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" BorderThickness="0" Click="BtnOk_Click"/>
            <Button Content="Hủy" Width="70" Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
