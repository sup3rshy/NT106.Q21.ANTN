<Window x:Class="NetDraw.Client.TemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn Template" Height="450" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chọn mẫu template" Foreground="#CDD6F4" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox x:Name="LstTemplates" Grid.Row="1" Background="#313244" BorderBrush="#45475A"
                 Foreground="#CDD6F4" FontSize="13" SelectionMode="Single"
                 MouseDoubleClick="LstTemplates_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4,6">
                        <Border Width="60" Height="45" Background="#181825" CornerRadius="4" Margin="0,0,10,0">
                            <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#89B4FA"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#CDD6F4" FontSize="13"/>
                            <TextBlock Text="{Binding Description}" Foreground="#A6ADC8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Chọn" Width="80" Margin="0,0,8,0" Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" BorderThickness="0" Padding="6" Click="BtnOk_Click" Cursor="Hand"/>
            <Button Content="Hủy" Width="80" Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Padding="6" Click="BtnCancel_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
