<Window x:Class="NetDraw.Client.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn màu" Height="420" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Gradient Color Area -->
        <TextBlock Grid.Row="0" Text="Chọn màu" Foreground="#CDD6F4" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>

        <!-- RGB Sliders -->
        <StackPanel Grid.Row="1">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="R" Foreground="#FF6B6B" FontWeight="Bold" VerticalAlignment="Center"/>
                <Slider x:Name="SliderR" Grid.Column="1" Minimum="0" Maximum="255" Value="0" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="TxtR" Grid.Column="2" Text="0" Foreground="#CDD6F4" FontSize="11" TextAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="G" Foreground="#A6E3A1" FontWeight="Bold" VerticalAlignment="Center"/>
                <Slider x:Name="SliderG" Grid.Column="1" Minimum="0" Maximum="255" Value="0" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="TxtG" Grid.Column="2" Text="0" Foreground="#CDD6F4" FontSize="11" TextAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="B" Foreground="#89B4FA" FontWeight="Bold" VerticalAlignment="Center"/>
                <Slider x:Name="SliderB" Grid.Column="1" Minimum="0" Maximum="255" Value="0" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="TxtB" Grid.Column="2" Text="0" Foreground="#CDD6F4" FontSize="11" TextAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- Preview + Hex -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Center">
            <Border x:Name="ColorPreview" Width="60" Height="60" Background="Black" BorderBrush="#45475A" BorderThickness="2" CornerRadius="5"/>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="HEX:" Foreground="#A6ADC8" FontSize="11"/>
                <TextBox x:Name="TxtHex" Text="#000000" Background="#313244" Foreground="#CDD6F4"
                         BorderBrush="#45475A" FontSize="14" FontFamily="Consolas" Width="100" Padding="4,3"
                         TextChanged="TxtHex_TextChanged"/>
            </StackPanel>
        </StackPanel>

        <!-- Quick Colors (bảng màu nhanh) -->
        <WrapPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,4">
            <!-- Row 1: Basic -->
            <Button Width="22" Height="22" Background="#000000" Margin="1" Click="QuickColor_Click" Tag="#000000" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FFFFFF" Margin="1" Click="QuickColor_Click" Tag="#FFFFFF" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#808080" Margin="1" Click="QuickColor_Click" Tag="#808080" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#C0C0C0" Margin="1" Click="QuickColor_Click" Tag="#C0C0C0" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FF0000" Margin="1" Click="QuickColor_Click" Tag="#FF0000" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FF6B6B" Margin="1" Click="QuickColor_Click" Tag="#FF6B6B" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FF8C00" Margin="1" Click="QuickColor_Click" Tag="#FF8C00" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FFD700" Margin="1" Click="QuickColor_Click" Tag="#FFD700" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FFFF00" Margin="1" Click="QuickColor_Click" Tag="#FFFF00" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#7FFF00" Margin="1" Click="QuickColor_Click" Tag="#7FFF00" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#00FF00" Margin="1" Click="QuickColor_Click" Tag="#00FF00" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#32CD32" Margin="1" Click="QuickColor_Click" Tag="#32CD32" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#00CED1" Margin="1" Click="QuickColor_Click" Tag="#00CED1" BorderThickness="1" BorderBrush="#45475A"/>
            <!-- Row 2 -->
            <Button Width="22" Height="22" Background="#00BFFF" Margin="1" Click="QuickColor_Click" Tag="#00BFFF" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#0000FF" Margin="1" Click="QuickColor_Click" Tag="#0000FF" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#3498DB" Margin="1" Click="QuickColor_Click" Tag="#3498DB" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#6A5ACD" Margin="1" Click="QuickColor_Click" Tag="#6A5ACD" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#9B59B6" Margin="1" Click="QuickColor_Click" Tag="#9B59B6" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#800080" Margin="1" Click="QuickColor_Click" Tag="#800080" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FF69B4" Margin="1" Click="QuickColor_Click" Tag="#FF69B4" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FF1493" Margin="1" Click="QuickColor_Click" Tag="#FF1493" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#DC143C" Margin="1" Click="QuickColor_Click" Tag="#DC143C" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#8B0000" Margin="1" Click="QuickColor_Click" Tag="#8B0000" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#8B4513" Margin="1" Click="QuickColor_Click" Tag="#8B4513" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#DEB887" Margin="1" Click="QuickColor_Click" Tag="#DEB887" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#F5DEB3" Margin="1" Click="QuickColor_Click" Tag="#F5DEB3" BorderThickness="1" BorderBrush="#45475A"/>
            <!-- Row 3: Pastels -->
            <Button Width="22" Height="22" Background="#FFB3BA" Margin="1" Click="QuickColor_Click" Tag="#FFB3BA" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FFDFBA" Margin="1" Click="QuickColor_Click" Tag="#FFDFBA" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#FFFFBA" Margin="1" Click="QuickColor_Click" Tag="#FFFFBA" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#BAFFC9" Margin="1" Click="QuickColor_Click" Tag="#BAFFC9" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#BAE1FF" Margin="1" Click="QuickColor_Click" Tag="#BAE1FF" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#E8BAFF" Margin="1" Click="QuickColor_Click" Tag="#E8BAFF" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#2F4F4F" Margin="1" Click="QuickColor_Click" Tag="#2F4F4F" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#191970" Margin="1" Click="QuickColor_Click" Tag="#191970" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#228B22" Margin="1" Click="QuickColor_Click" Tag="#228B22" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#B8860B" Margin="1" Click="QuickColor_Click" Tag="#B8860B" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#4682B4" Margin="1" Click="QuickColor_Click" Tag="#4682B4" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#D2691E" Margin="1" Click="QuickColor_Click" Tag="#D2691E" BorderThickness="1" BorderBrush="#45475A"/>
            <Button Width="22" Height="22" Background="#BC8F8F" Margin="1" Click="QuickColor_Click" Tag="#BC8F8F" BorderThickness="1" BorderBrush="#45475A"/>
        </WrapPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Chọn" Width="80" Margin="0,0,8,0" Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" BorderThickness="0" Padding="6" Click="BtnOk_Click" Cursor="Hand"/>
            <Button Content="Hủy" Width="80" Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Padding="6" Click="BtnCancel_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
