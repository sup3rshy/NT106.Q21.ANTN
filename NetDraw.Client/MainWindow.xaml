<Window x:Class="NetDraw.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NetDraw - Vẽ chung qua mạng" Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <!-- Button Style -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ColorBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#CDD6F4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>     <!-- Toolbar -->
            <ColumnDefinition Width="*"/>       <!-- Canvas -->
            <ColumnDefinition Width="280"/>     <!-- Sidebar -->
        </Grid.ColumnDefinitions>

        <!-- === TOOLBAR (Left) === -->
        <Border Grid.Column="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,1,0">
            <StackPanel Margin="8,10">
                <TextBlock Text="Tools" Foreground="#A6ADC8" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                <Button x:Name="BtnPen" Style="{StaticResource ToolBtn}" Content="✏" ToolTip="Bút vẽ (P)" Click="BtnPen_Click"/>
                <Button x:Name="BtnLine" Style="{StaticResource ToolBtn}" Content="╱" ToolTip="Đường thẳng (L)" Click="BtnLine_Click"/>
                <Button x:Name="BtnRect" Style="{StaticResource ToolBtn}" Content="▭" ToolTip="Hình chữ nhật (R)" Click="BtnRect_Click"/>
                <Button x:Name="BtnCircle" Style="{StaticResource ToolBtn}" Content="○" ToolTip="Hình tròn (C)" Click="BtnCircle_Click"/>
                <Button x:Name="BtnEllipse" Style="{StaticResource ToolBtn}" Content="⬭" ToolTip="Hình elip (E)" Click="BtnEllipse_Click"/>
                <Button x:Name="BtnTriangle" Style="{StaticResource ToolBtn}" Content="△" ToolTip="Tam giác (T)" Click="BtnTriangle_Click"/>
                <Button x:Name="BtnText" Style="{StaticResource ToolBtn}" Content="A" ToolTip="Chèn text" Click="BtnText_Click"/>
                <Button x:Name="BtnEraser" Style="{StaticResource ToolBtn}" Content="⌫" ToolTip="Tẩy (X)" Click="BtnEraser_Click"/>

                <Separator Background="#45475A" Margin="0,8"/>

                <TextBlock Text="Size" Foreground="#A6ADC8" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                <Slider x:Name="SliderSize" Minimum="1" Maximum="30" Value="2" Orientation="Vertical" Height="80" HorizontalAlignment="Center"
                        ValueChanged="SliderSize_ValueChanged"/>
                <TextBlock x:Name="TxtSize" Text="2" Foreground="#CDD6F4" FontSize="10" HorizontalAlignment="Center"/>

                <Separator Background="#45475A" Margin="0,8"/>

                <CheckBox x:Name="ChkFill" Content="Fill" Foreground="#CDD6F4" HorizontalAlignment="Center" FontSize="10"/>

                <Separator Background="#45475A" Margin="0,8"/>

                <Button Style="{StaticResource ToolBtn}" Content="↩" ToolTip="Undo (Ctrl+Z)" Click="BtnUndo_Click"/>
                <Button Style="{StaticResource ToolBtn}" Content="↪" ToolTip="Redo (Ctrl+Y)" Click="BtnRedo_Click"/>
                <Button Style="{StaticResource ToolBtn}" Content="🗑" ToolTip="Xóa tất cả" Click="BtnClear_Click"/>
                <Button Style="{StaticResource ToolBtn}" Content="💾" ToolTip="Xuất ảnh PNG" Click="BtnExport_Click"/>
            </StackPanel>
        </Border>

        <!-- === CANVAS (Center) === -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>   <!-- Color bar -->
                <RowDefinition Height="*"/>     <!-- Canvas -->
                <RowDefinition Height="45"/>    <!-- AI Command bar -->
            </Grid.RowDefinitions>

            <!-- Color Palette -->
            <Border Grid.Row="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <Button Style="{StaticResource ColorBtn}" Background="#000000" Tag="#000000" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#FFFFFF" Tag="#FFFFFF" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#FF0000" Tag="#FF0000" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#FF6B6B" Tag="#FF6B6B" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#FF8C00" Tag="#FF8C00" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#FFD700" Tag="#FFD700" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#00FF00" Tag="#00FF00" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#32CD32" Tag="#32CD32" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#0000FF" Tag="#0000FF" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#3498DB" Tag="#3498DB" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#9B59B6" Tag="#9B59B6" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#FF69B4" Tag="#FF69B4" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#8B4513" Tag="#8B4513" Click="ColorBtn_Click"/>
                    <Button Style="{StaticResource ColorBtn}" Background="#808080" Tag="#808080" Click="ColorBtn_Click"/>

                    <Separator Width="1" Background="#45475A" Margin="8,4"/>
                    <Border x:Name="CurrentColorPreview" Width="32" Height="32" Background="Black" BorderBrush="#CDD6F4" BorderThickness="2" CornerRadius="4"/>
                    <TextBlock x:Name="TxtCurrentColor" Text="#000000" Foreground="#CDD6F4" VerticalAlignment="Center" Margin="5,0" FontSize="11"/>

                    <Separator Width="1" Background="#45475A" Margin="8,4"/>
                    <TextBlock x:Name="TxtToolName" Text="Bút vẽ" Foreground="#89B4FA" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Drawing Canvas -->
            <Border Grid.Row="1" Background="#FFFFFF" Margin="5" BorderBrush="#45475A" BorderThickness="1" ClipToBounds="True">
                <Canvas x:Name="DrawCanvas"
                        Background="White"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        ClipToBounds="True"/>
            </Border>

            <!-- AI Command Bar -->
            <Border Grid.Row="2" Background="#181825" BorderBrush="#313244" BorderThickness="0,1,0,0">
                <Grid Margin="10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🤖 AI:" Foreground="#F9E2AF" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtAiCommand" Grid.Column="1"
                             Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                             FontSize="13" Padding="8,5" VerticalContentAlignment="Center"
                             Text="" ToolTip="Nhập lệnh vẽ AI, ví dụ: vẽ hình tròn màu đỏ ở giữa"
                             KeyDown="TxtAiCommand_KeyDown"/>
                    <Button Grid.Column="2" Content="Gửi" Width="60" Margin="5,0,0,0"
                            Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold" BorderThickness="0"
                            Click="BtnAiSend_Click" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>

        <!-- === SIDEBAR (Right) === -->
        <Border Grid.Column="2" Background="#181825" BorderBrush="#313244" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>    <!-- Connection -->
                    <RowDefinition Height="Auto"/>    <!-- Room -->
                    <RowDefinition Height="140"/>     <!-- Users -->
                    <RowDefinition Height="*"/>        <!-- Chat -->
                    <RowDefinition Height="Auto"/>    <!-- Chat input -->
                </Grid.RowDefinitions>

                <!-- Connection Panel -->
                <StackPanel Grid.Row="0" Margin="10">
                    <TextBlock Text="KẾT NỐI" Foreground="#A6ADC8" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="TxtServerIp" Grid.Row="0" Grid.ColumnSpan="2"
                                 Text="127.0.0.1" Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" FontSize="12" Padding="5,3" Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtPort" Grid.Row="1" Grid.Column="0"
                                 Text="5000" Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" FontSize="12" Padding="5,3" Margin="0,0,3,3"/>
                        <TextBox x:Name="TxtUserName" Grid.Row="1" Grid.Column="1"
                                 Text="" Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" FontSize="12" Padding="5,3" Margin="0,0,0,3"
                                 ToolTip="Tên của bạn"/>
                        <Button x:Name="BtnConnect" Grid.Row="2" Grid.ColumnSpan="2"
                                Content="Kết nối" Background="#A6E3A1" Foreground="#1E1E2E"
                                FontWeight="Bold" BorderThickness="0" Padding="5" Cursor="Hand"
                                Click="BtnConnect_Click"/>
                    </Grid>
                    <TextBlock x:Name="TxtStatus" Text="Chưa kết nối" Foreground="#F38BA8" FontSize="11" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Room Panel -->
                <StackPanel Grid.Row="1" Margin="10,0,10,5">
                    <TextBlock Text="PHÒNG VẼ" Foreground="#A6ADC8" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtRoomId" Grid.Column="0" Text="default"
                                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                                 FontSize="12" Padding="5,3" Margin="0,0,3,0"/>
                        <Button x:Name="BtnJoinRoom" Grid.Column="1" Content="Vào"
                                Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" Click="BtnJoinRoom_Click"/>
                    </Grid>
                    <TextBlock x:Name="TxtRoomName" Text="" Foreground="#A6E3A1" FontSize="11" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Users Panel -->
                <Border Grid.Row="2" Margin="10,0,10,5" Background="#11111B" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="NGƯỜI DÙNG ONLINE" Foreground="#A6ADC8" FontSize="11" FontWeight="Bold" Margin="8,5"/>
                        <ListBox x:Name="LstUsers" Background="Transparent" BorderThickness="0" Foreground="#CDD6F4" FontSize="12"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    </StackPanel>
                </Border>

                <!-- Chat Messages -->
                <Border Grid.Row="3" Margin="10,0,10,5" Background="#11111B" CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CHAT" Foreground="#A6ADC8" FontSize="11" FontWeight="Bold" Margin="8,5"/>
                        <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtChat" Foreground="#CDD6F4" FontSize="12" TextWrapping="Wrap" Margin="8,0,8,5"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Chat Input -->
                <Grid Grid.Row="4" Margin="10,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtChatInput" Grid.Column="0"
                             Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                             FontSize="12" Padding="5,3" KeyDown="TxtChatInput_KeyDown"/>
                    <Button Grid.Column="1" Content="↵" Background="#89B4FA" Foreground="#1E1E2E"
                            FontWeight="Bold" FontSize="16" BorderThickness="0" Cursor="Hand"
                            Click="BtnChatSend_Click" Margin="3,0,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
