<Window x:Class="NetDraw.Client.ImageImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import ảnh" Height="520" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Xem trước ảnh" Foreground="#CDD6F4" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>

        <!-- Preview -->
        <Border Grid.Row="1" Background="#313244" BorderBrush="#45475A" BorderThickness="1" CornerRadius="4">
            <Image x:Name="ImgPreview" Stretch="Uniform" Margin="8"/>
        </Border>

        <!-- Filters -->
        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="BỘ LỌC" Foreground="#6C7086" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
            <WrapPanel>
                <RadioButton x:Name="RbOriginal" Content="Gốc" Foreground="#CDD6F4" IsChecked="True" Margin="0,0,12,4" Checked="Filter_Changed"/>
                <RadioButton x:Name="RbGrayscale" Content="Đen trắng" Foreground="#CDD6F4" Margin="0,0,12,4" Checked="Filter_Changed"/>
                <RadioButton x:Name="RbSepia" Content="Sepia (Cổ điển)" Foreground="#CDD6F4" Margin="0,0,12,4" Checked="Filter_Changed"/>
                <RadioButton x:Name="RbInvert" Content="Âm bản" Foreground="#CDD6F4" Margin="0,0,12,4" Checked="Filter_Changed"/>
                <RadioButton x:Name="RbHighContrast" Content="Tương phản cao" Foreground="#CDD6F4" Margin="0,0,12,4" Checked="Filter_Changed"/>
                <RadioButton x:Name="RbSketch" Content="Phác thảo" Foreground="#CDD6F4" Margin="0,0,12,4" Checked="Filter_Changed"/>
            </WrapPanel>
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Kích thước %" Foreground="#A6ADC8" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider x:Name="SliderScale" Grid.Column="1" Minimum="10" Maximum="200" Value="100" VerticalAlignment="Center"
                        ValueChanged="SliderScale_ValueChanged"/>
                <TextBlock x:Name="TxtScale" Grid.Column="2" Text="100%" Foreground="#CDD6F4" FontSize="11" VerticalAlignment="Center" TextAlignment="Right"/>
            </Grid>
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Import" Width="80" Margin="0,0,8,0" Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" BorderThickness="0" Padding="6" Click="BtnOk_Click" Cursor="Hand"/>
            <Button Content="Hủy" Width="80" Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Padding="6" Click="BtnCancel_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
